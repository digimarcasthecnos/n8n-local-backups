      "parameters": {
        "jsCode": "// A variável $input.first().json.data contém o array de workflows.\nconst workflows = $input.first().json.data;\n\n// Mapeia o array de workflows para um novo array onde cada workflow\n// é encapsulado como um item individual para o n8n.\nconst output = workflows.map(workflow => {\n  return {\n    json: workflow\n  };\n});\n\n// Retorna o array de itens.\nreturn output;"
