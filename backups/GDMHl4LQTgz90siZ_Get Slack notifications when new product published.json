{
  "updatedAt": "2026-05-13T23:04:41.907Z",
  "createdAt": "2026-05-13T23:04:41.907Z",
  "id": "GDMHl4LQTgz90siZ",
  "name": "Get Slack notifications when new product published on WooCommerce",
  "active": false,
  "isArchived": false,
  "nodes": [
    {
      "name": "If URL has /product/",
      "type": "n8n-nodes-base.if",
      "position": [
        640,
        300
      ],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json[\"permalink\"]}}",
              "value2": "https://[add-your-url-here]/product/",
              "operation": "startsWith"
            }
          ]
        }
      },
      "typeVersion": 1,
      "id": "a7830821-0cba-4978-852a-9f109e1d0fa7"
    },
    {
      "name": "Send message to slack",
      "type": "n8n-nodes-base.slack",
      "position": [
        920,
        260
      ],
      "parameters": {
        "text": ":new: A new product has been added! :new:",
        "channel": "newproducts",
        "blocksUi": {
          "blocksValues": []
        },
        "attachments": [
          {
            "color": "#66FF00",
            "fields": {
              "item": [
                {
                  "short": false,
                  "title": "Name",
                  "value": "={{$json[\"name\"]}}"
                },
                {
                  "short": true,
                  "title": "Price",
                  "value": "={{$json[\"regular_price\"]}}"
                },
                {
                  "short": true,
                  "title": "Sale Price",
                  "value": "={{$json[\"sale_price\"]}}"
                },
                {
                  "short": false,
                  "title": "Link",
                  "value": "={{$json[\"permalink\"]}}"
                }
              ]
            },
            "footer": "=Added: {{$json[\"date_created\"]}}"
          }
        ],
        "otherOptions": {}
      },
      "credentials": {
        "slackApi": {
          "id": "credential-id",
          "name": "slackApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "0b3d2e0a-fd50-4792-86c1-540ade6fe0c0"
    },
    {
      "name": "On product creation",
      "type": "n8n-nodes-base.wooCommerceTrigger",
      "position": [
        460,
        300
      ],
      "webhookId": "267c4855-6227-4d33-867e-74600097473e",
      "parameters": {
        "event": "product.created"
      },
      "credentials": {
        "wooCommerceApi": {
          "id": "credential-id",
          "name": "wooCommerceApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "a6071244-7111-4d13-be92-e8bf0f44ccd1"
    }
  ],
  "connections": {
    "On product creation": {
      "main": [
        [
          {
            "node": "If URL has /product/",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "If URL has /product/": {
      "main": [
        [
          {
            "node": "Send message to slack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
