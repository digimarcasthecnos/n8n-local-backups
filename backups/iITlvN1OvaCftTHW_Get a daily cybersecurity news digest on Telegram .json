    {
      "id": "5ae19667-b8f5-4eb6-81c7-fca6d6b714ab",
      "name": "Manipulating Outputs",
      "type": "n8n-nodes-base.code",
      "position": [
        2768,
        720
      ],
      "parameters": {
        "jsCode": "const aiText = items[0].json.output;\n\n// 1️⃣ Unified text message (Telegram / Slack / Email)\nconst message =\n`🛡️ Daily Cybersecurity Brief\n\n${aiText}\n\n🕒 Generated: ${new Date().toLocaleString()}`;\n\n// 2️⃣ Basic row format for Sheets (1 row per digest)\nconst sheetRow = {\n  date: new Date().toISOString(),\n  content: aiText\n};\n\nreturn [{\n  json: {\n    textMessage: message,\n    sheetRow,\n    metadata: {\n      generatedAt: new Date().toISOString(),\n      length: aiText.length\n    }\n  }\n}];\n"
      },
      "typeVersion": 2
    },
