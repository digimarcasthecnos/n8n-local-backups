            {
              "value1": "={{$json[\"name\"]}}",
              "value2": "Max",
              "operation": "contains"
            }
          ]
        },
        "combineOperation": "any"
      },
      "typeVersion": 1,
      "id": "6aad4ea0-667b-4d41-b483-f0ebfadf43d5"
    },
