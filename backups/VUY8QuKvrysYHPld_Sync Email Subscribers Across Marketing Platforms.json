      "parameters": {
        "functionCode": "const emailSet = new Set();\nconst uniqueSubs = [];\nfor (const item of items) {\n  if (!emailSet.has(item.json.email)) {\n    uniqueSubs.push(item);\n    emailSet.add(item.json.email);\n  }\n}\nreturn uniqueSubs;"
      }
