      "webhookId": "00724f92-9755-4dd9-b88e-f6e0b5ad01b0",
      "parameters": {
        "text": "={{ $json.text }}",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "mode": "name",
          "value": "general"
        },
