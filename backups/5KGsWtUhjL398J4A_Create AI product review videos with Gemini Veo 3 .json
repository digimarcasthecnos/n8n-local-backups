        "jsonSchemaExample": "{\n  \"video_title\" : \"string\",\n  \"video_description\": \"string\",\n  \"scenes\": {\n  \"scene_1\": {\n    \"video_prompt\": \"string\"\n  },\n  \"scene_2\": {\n    \"video_prompt\": \"string\"\n   \n  },\n  \"scene_3\": {\n    \"video_prompt\": \"string\"\n  }\n}\n}"
      },
      "typeVersion": 1.3
