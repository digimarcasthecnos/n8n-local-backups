        "options": {},
        "authentication": "appToken",
        "additionalFields": {
          "city": "={{ $json.city }}",
          "firstName": "={{ $json.name }}",
          "websiteUrl": "interwood.pk",
          "mobilePhoneNumber": "={{ $json.phone }}"
        }
      },
      "typeVersion": 2.1,
      "id": "7955e68e-40ab-4e5d-8f23-a8c36a0ea75d"
    },
    {
      "name": "Create a deal",
      "type": "n8n-nodes-base.hubspot",
      "position": [
