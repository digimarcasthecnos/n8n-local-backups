          "customPropertiesUi": {
            "customPropertiesValues": [
              {
                "value": "Yes",
                "property": "paid"
              }
            ]
          }
        },
        "authentication": "oAuth2"
      },
      "credentials": {
        "hubspotOAuth2Api": {
          "id": "credential-id",
          "name": "hubspotOAuth2Api Credential"
        }
      },
      "typeVersion": 1,
      "id": "bd3dc163-20f4-461b-865b-6ff3de317305"
    },
    {
