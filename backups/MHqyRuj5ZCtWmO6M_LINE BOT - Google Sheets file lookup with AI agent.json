    {
      "id": "da38d327-be4c-463a-8d7e-a3d54fd0f195",
      "name": "IF File Exists",
      "type": "n8n-nodes-base.if",
      "position": [
        -160,
        480
      ],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json['File URL'] }}",
              "operation": "isEmpty"
