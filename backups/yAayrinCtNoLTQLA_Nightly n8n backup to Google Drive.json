    {
      "id": "0d09ed07-6d1e-4ead-afc6-9f6e3788b90f",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "position": [
        240,
        272
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst requiredNames = [\"n8n_old\", \"n8n_backups\"];\n\n// Creamos un mapa de lo que ya existe\nconst existingFolders = {};\nitems.forEach(item => {\n  existingFolders[item.json.name] = item.json.id;\n});\n\n// Verificamos qué falta\nconst missingNames = requiredNames.filter(name => !existingFolders[name]);\n\nreturn [{\n  json: {\n    message: missingNames.length === 0 ? \"ok\" : `Faltan: ${missingNames.join(', ')}`,\n    ids: existingFolders, // Guardamos los IDs aquí\n    missing: missingNames\n  }\n}];"
      },
      "typeVersion": 2
    },
