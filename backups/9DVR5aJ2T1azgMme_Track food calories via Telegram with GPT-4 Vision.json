  "id": "9DVR5aJ2T1azgMme",
  "name": "Track food calories via Telegram with GPT-4 Vision and Google Sheets",
  "active": false,
  "isArchived": false,
  "nodes": [
    {
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "position": [
        200,
        300
      ],
      "parameters": {
        "updates": [
          "message"
        ]
      },
      "credentials": {
        "telegramApi": {
          "id": "credential-id",
          "name": "telegramApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "a5e527fd-5b9a-4a20-aafd-60ab27cc7a2b",
      "webhookId": "3aa706e4-255a-4b19-a296-9c55d523dd7f"
    },
    {
      "name": "Sticky Note: Acknowledge",
      "type": "n8n-nodes-base.telegram",
      "position": [
        400,
        300
      ],
      "parameters": {
        "text": "🧠 Thanks! I’m analyzing your food image now...",
        "chatId": "={{$json[\"message\"][\"chat\"][\"id\"]}}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "credential-id",
          "name": "telegramApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "93029c3e-4797-4256-bfb9-efb55aa8aec5",
      "webhookId": "ce8063ef-c405-48c9-8abe-e7b0a5d482ac"
    },
    {
      "name": "Download Telegram Image",
      "type": "n8n-nodes-base.telegram",
      "position": [
        600,
        300
      ],
      "parameters": {
        "fileId": "={{$json[\"message\"][\"photo\"][ $json[\"message\"][\"photo\"].length - 1 ][\"file_id\"]}}",
        "resource": "file",
        "operation": "download"
      },
      "credentials": {
        "telegramApi": {
          "id": "credential-id",
          "name": "telegramApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "8126a9a3-396b-4158-950e-d97fb5297083",
      "webhookId": "facbe561-6f1a-481d-bb2f-5bfb66c80f88"
    },
    {
      "name": "Prepare Binary Image",
      "type": "n8n-nodes-base.function",
      "position": [
        800,
        300
      ],
      "parameters": {
        "functionCode": "return [{ binary: { image: items[0].binary.data } }];"
      },
      "typeVersion": 1,
      "id": "85da898d-d157-4f84-b136-beaa8de32394"
    },
    {
      "name": "GPT-4 Vision Analyze",
      "type": "n8n-nodes-base.openai",
      "position": [
        1000,
        300
      ],
      "parameters": {
        "model": "gpt-4-vision-preview",
        "messages": [
          {
            "role": "user",
            "content": [
              {
                "text": "Describe this food and estimate its calories.",
                "type": "text"
              },
              {
                "type": "image_url",
                "image_url": "={{$binary.image.data}}"
              }
            ]
          }
        ]
      },
      "credentials": {
        "openAiApi": {
          "id": "credential-id",
          "name": "openAiApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "30e5f970-fe49-4b2a-8419-247900af3113"
    },
    {
      "name": "Log to Google Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        1200,
        300
      ],
      "parameters": {
        "range": "Sheet1!A:C",
        "values": "={{ [[new Date().toISOString(), $json[\"text\"]]] }}",
        "options": {},
        "sheetId": "{{GOOGLE_SHEET_ID}}",
        "authentication": "oAuth2"
      },
      "credentials": {
        "googleApi": {
          "id": "credential-id",
          "name": "googleApi Credential"
        }
      },
      "typeVersion": 2,
      "id": "5805599e-da1b-439e-9a77-6d39634ea837"
    },
    {
      "name": "Send GPT Result",
      "type": "n8n-nodes-base.telegram",
      "position": [
        1400,
        300
      ],
      "parameters": {
        "text": "={{$json[\"text\"]}}",
        "chatId": "={{$json[\"message\"][\"chat\"][\"id\"]}}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "credential-id",
          "name": "telegramApi Credential"
        }
      },
      "typeVersion": 1,
      "id": "f5a8bb62-aa69-4acf-8a9e-9e000fc57da3",
      "webhookId": "359b298b-1e61-4c99-a041-06fdcc78f979"
    }
  ],
  "connections": {
    "Telegram Trigger": {
      "main": [
        [
          {
            "node": "Sticky Note: Acknowledge",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GPT-4 Vision Analyze": {
      "main": [
        [
          {
            "node": "Log to Google Sheet",
            "type": "main",
            "index": 0
          },
          {
            "node": "Send GPT Result",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Prepare Binary Image": {
      "main": [
        [
          {
            "node": "GPT-4 Vision Analyze",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Download Telegram Image": {
      "main": [
        [
          {
            "node": "Prepare Binary Image",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Sticky Note: Acknowledge": {
      "main": [
        [
          {
            "node": "Download Telegram Image",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
