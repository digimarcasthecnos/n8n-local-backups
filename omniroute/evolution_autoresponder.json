    {
      "parameters": {
        "jsCode": "\nconst body = $json.body || $json;\nconst data = body.data || body;\nconst key = data.key || {};\nconst remoteJid = key.remoteJid || '';\nconst fromMe = !!key.fromMe;\nconst message = data.message || {};\nconst text = message.conversation || (message.extendedTextMessage && message.extendedTextMessage.text) || '';\nconst pushName = data.pushName || 'cliente';\nconst isGroup = remoteJid.endsWith('@g.us');\n\nconst now = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));\nconst hour = now.getHours();\nlet saudacao;\nif (hour >= 5 && hour <= 11) saudacao = 'Bom dia';\nelse if (hour >= 12 && hour <= 17) saudacao = 'Boa tarde';\nelse saudacao = 'Boa noite';\n\nconst menuText = `*${saudacao}, ${pushName}!* \\u{1F44B}\n\n*Seja bem-vindo(a) à DigiMarcas Thecnos* \\u{1F680}\n\n*Sou o assistente virtual da DigiMarcas. Como posso te ajudar hoje?*\n\n*1\\u{FE0F}\\u{20E3} – Desenvolvimento de Sites / WordPress*\n*2\\u{FE0F}\\u{20E3} – Automação com n8n e Inteligência Artificial*\n*3\\u{FE0F}\\u{20E3} – Marketing Digital e Afiliados*\n*4\\u{FE0F}\\u{20E3} – Suporte Técnico*\n*5\\u{FE0F}\\u{20E3} – Falar com um atendente humano*\n\n*Digite o número da opção desejada.* \\u{1F60A}`;\n\nreturn [{ json: { remoteJid, fromMe, text, pushName, isGroup, menuText } }];\n"
      },
      "id": "n2",
      "name": "ExtractMessage",
