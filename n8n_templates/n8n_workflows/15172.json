          "webhookId": "44b6f616-7e75-43e7-aba5-9afcb6e5a185",
          "parameters": {
            "text": "=🛢️ <b>Brent Crude Oil Futures</b>\n📅 {{ $json.data[0].scrape_date }} • {{ $json.data[0].scrape_time }}\n\n{{ $json.data.every(item => item.change >= 0) ? '✅ ALL UP' : $json.data.every(item => item.change < 0) ? '⚠️ ALL DOWN' : '📊 MIXED' }}\n━━━━━━━━━━━━━━━━━━━━━━\n\n<pre>\nContract  Period    Price   Change\n───────────────────────────────────\n{{ $json.data.map(item => {\n  const emoji = item.change > 0 ? '🟢' : item.change < 0 ? '🔴' : '⚪';\n  const symbol = item.symbol.padEnd(9);\n  const period = `${item.month} '${String(item.year).slice(-2)}`.padEnd(9);\n  const price = `$${item.price_usd}`.padEnd(7);\n  const change = `${item.change >= 0 ? '+' : ''}$${item.change}`;\n  return `${emoji} ${symbol} ${period} ${price} ${change}`;\n}).join('\\n') }}\n</pre>\n\n📊 Range: ${{ Math.min(...$json.data.map(d => d.price_usd)) }} - ${{ Math.max(...$json.data.map(d => d.price_usd)) }}\n📈 Avg: {{ ($json.data.reduce((sum, d) => sum + d.change, 0) / $json.data.length).toFixed(2) >= 0 ? '+' : '' }}${{ ($json.data.reduce((sum, d) => sum + d.change, 0) / $json.data.length).toFixed(2) }}\n\n🔗 <a href=\"{{ $json.data[0].source }}\">Source</a>",
            "chatId": "123456789",
