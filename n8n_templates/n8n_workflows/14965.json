          "id": "8516e4aa-3c7c-4d1b-b059-4ca0f4064796",
          "name": "Mighty Networks Webhook",
          "type": "n8n-nodes-base.webhook",
          "position": [
            48,
            672
          ],
          "webhookId": "mighty-networks-new-member",
          "parameters": {
            "path": "mighty-networks-new-member",
            "options": {},
            "httpMethod": "POST"
          },
          "typeVersion": 2
