            0
          ],
          "parameters": {
            "emailField": "={{ $json.Email }}",
            "additionalFields": {}
          },
          "typeVersion": 1
        },
        {
          "id": "9e82e251-21fa-4330-a1e7-adefe6da39ac",
          "name": "Check if Status = Valid",
          "type": "n8n-nodes-base.if",
          "position": [
            416,
            0
          ],
          "parameters": {
            "conditions": {
              "conditions": [
                {
                  "operator": {
                    "name": "filter.operator.equals",
                    "type": "string",
                    "operation": "equals"
                  },
                  "leftValue": "={{ $json.verification_result.status }}",
                  "rightValue": "valid"
                }
              ]
            }
          },
          "typeVersion": 2.3
