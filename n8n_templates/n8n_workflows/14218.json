        {
          "id": "cc90dbab-a7ed-4ee4-b1e4-625b8a17f663",
          "name": "new workflows",
          "type": "n8n-nodes-base.httpRequest",
          "position": [
            992,
            -256
          ],
          "parameters": {
            "url": "={{ $(\"config\").item.json.new_url }}/api/v1/workflows",
            "options": {},
