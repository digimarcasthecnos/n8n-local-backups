                },
                {
                  "name": "Content-Type",
                  "value": "application/json"
                }
              ]
            }
          },
          "typeVersion": 4.2
        },
        {
          "id": "74d79b87-8988-4bb1-8840-8bb1f097a027",
          "name": "🔀 Split by Company",
