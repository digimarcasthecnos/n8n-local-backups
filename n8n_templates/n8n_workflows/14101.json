        {
          "id": "70587664-5c2e-4e57-aca4-c0c2a2a06641",
          "name": "🏢 Get Company Info",
          "type": "n8n-nodes-base.httpRequest",
          "position": [
            1424,
            176
          ],
          "parameters": {
            "url": "=https://predictleads.com/api/v3/companies/{{ $('set domain').item.json.domain }}",
            "options": {},
            "sendHeaders": true,
            "headerParameters": {
              "parameters": [
                {
                  "name": "X-Api-Key",
                  "value": "YOUR_PREDICTLEADS_API_KEY"
