                  "value": "={{ (() => {\n  const prefix = ($('Input: Prefix + tag names').item.json.prefix || '').trim();\n  const tag = String($json.tagNames || '').trim();\n\n  if (!prefix) return tag;\n  return prefix.endsWith(' ') ? prefix + tag : prefix + ' ' + tag;\n})() }}"
