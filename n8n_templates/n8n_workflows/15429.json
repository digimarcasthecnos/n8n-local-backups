          ],
          "webhookId": "c78bb2ef-1e58-42f3-86c8-13542878c0ea",
          "parameters": {
            "message": "={{ .digest_html }}",
            "options": {
              "sendTo": "={{ .recipient_email }}"
            },
            "subject": "={{ .subject }}",
            "resource": "draft",
            "emailType": "html"
          },
          "credentials": {
            "gmailOAuth2": {
              "id": "credential-id",
              "name": "Gmail account"
            }
          },
          "typeVersion": 2.2
        },
