            "message": "={{ $json.report_body }}",
            "options": {},
            "subject": "={{ $json.subject_line }}"
          },
          "credentials": {
            "gmailOAuth2": {
              "id": "K59HBLBpV2ffh9x0",
              "name": "Gmail account"
            }
          },
          "typeVersion": 2.1
        },
        {
          "id": "9509f8bd-06f4-4b1e-b876-f6171e8b9a0a",
          "name": "Log Report Sent",
          "type": "n8n-nodes-base.googleSheets",
          "position": [
            1344,
            208
          ],
          "parameters": {
