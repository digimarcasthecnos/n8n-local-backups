            "formDescription": "Generate test questions from PDF materials"
          },
          "typeVersion": 2.5
        },
        {
          "id": "9f09d15c-af0f-4dc4-b001-02bad462747a",
          "name": "Extract PDF",
          "type": "n8n-nodes-base.extractFromFile",
