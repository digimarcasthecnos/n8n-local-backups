            "message": "<p>Dear {{ $('Form Trigger').item.json.Name }},</p><p>Your test has been generated!</p><p><strong>📄 Link:</strong><br><a href=\"https://docs.google.com/document/d/{{ $('Create Doc').item.json.id }}\">Open Document</a></p><p><strong>Details:</strong></p><ul><li>Subject: {{ $('Form Trigger').item.json.Subject }}</li><li>Grade: {{ $('Form Trigger').item.json.Grade }}</li><li>Questions: 10 (5 per group)</li></ul><p>✓ Two versions (Group A & B)<br>✓ Ready to print</p><hr><p><small>AI Test Generator</small></p>",
            "options": {},
