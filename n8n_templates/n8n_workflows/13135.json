{
  "workflow": {
    "id": 13135,
    "name": "Create anti-cheating tests from PDFs with GPT-4o-mini and Google Docs",
    "views": 43,
    "recentViews": 0,
    "totalViews": 43,
    "createdAt": "2026-01-31T21:49:23.224Z",
    "description": "Extract content from PDFs, generate two different test versions with AI, and create formatted Google Docs with automated email delivery.\nThis workflow extracts text from PDF teaching materials, uses OpenAI to generate 10 test questions in two different versions (Group A and B), creates a formatted Google Doc, and sends an email notification with the document link. Perfect for teachers who need to prevent student cheating while saving time on test creation.\n\nTools used: OpenAI GPT-4o-mini, Google Docs, Google Drive, Gmail",
    "workflow": {
      "id": "8cmZ2C8vmHtA9wLl6uaML",
      "meta": {
        "instanceId": "3c3a298b7629aaf1e96591b02fc4099512cb09e6e4fbad2c9a91b0f71f43dc3b"
      },
      "name": "Generate student tests from PDFs using AI and Google Docs",
      "tags": [],
      "nodes": [
