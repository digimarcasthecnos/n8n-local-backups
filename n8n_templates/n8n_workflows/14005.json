          "position": [
            528,
            -16
          ],
          "parameters": {
            "jsCode": "\nreturn $(\"New Outlook emal trigger\").all().flatMap(item => {\n  const binaries = item.binary ?? {};\n\n  return Object.keys(binaries).map(key => ({\n    json: {\n      ...item.json,\n    },\n    binary: {\n      data: binaries[key],\n    },\n  }));\n});"
          },
