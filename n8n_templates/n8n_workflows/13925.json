            "url": "={{ $('⚙️ Config').first().json.baseUrl }}/auth/ksef-token",
            "method": "POST",
            "options": {},
            "jsonBody": "={{ JSON.stringify($json) }}",
            "sendBody": true,
            "sendHeaders": true,
            "specifyBody": "json",
            "headerParameters": {
