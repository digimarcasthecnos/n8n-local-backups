            "jsonOutput": "{\n  \"baseUrl\": \"https://api.ksef.mf.gov.pl/v2\",\n  \"nip\": \"YOUR_NIP_HERE\",\n  \"authToken\": \"YOUR_KSEF_TOKEN_HERE\",\n  \"startDate\": \"2026-02-01T00:00:00Z\",\n  \"endDate\": \"2026-03-06T23:59:59Z\",\n  \"subjectType\": \"Subject2\"\n}"
