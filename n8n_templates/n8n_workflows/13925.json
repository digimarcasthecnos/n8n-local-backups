          ],
          "parameters": {
            "url": "={{ $('⚙️ Config').first().json.baseUrl }}/invoices/query/metadata",
            "method": "POST",
            "options": {
              "pagination": {
                "pagination": {
                  "parameters": {
                    "parameters": [
