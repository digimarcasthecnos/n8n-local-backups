                      }
                    ]
                  },
                  "completeExpression": "={{ $response.body.hasMore === false }}",
                  "paginationCompleteWhen": "other"
                }
              }
            },
            "jsonBody": "={{ JSON.stringify({ subjectType: $('⚙️ Config').first().json.subjectType, dateRange: { dateType: 'PermanentStorage', from: $('⚙️ Config').first().json.startDate, to: $('⚙️ Config').first().json.endDate } }) }}",
            "sendBody": true,
            "sendQuery": true,
            "sendHeaders": true,
            "specifyBody": "json",
            "queryParameters": {
              "parameters": [
                {
                  "name": "pageSize",
                  "value": "250"
