                          "type": "number",
                          "operation": "lte"
                        },
                        "leftValue": "={{ $json.anger_score }}",
                        "rightValue": 3
                      }
                    ]
                  },
                  "renameOutput": true
                }
              ]
            },
            "options": {}
          },
          "typeVersion": 3.2
        },
