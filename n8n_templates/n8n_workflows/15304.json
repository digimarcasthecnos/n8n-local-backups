                      "caseSensitive": true,
                      "typeValidation": "strict"
                    },
                    "combinator": "and",
                    "conditions": [
                      {
                        "operator": {
                          "type": "number",
                          "operation": "gte"
                        },
                        "leftValue": "={{ $json.anger_score }}",
                        "rightValue": 4
                      },
                      {
                        "operator": {
                          "type": "number",
                          "operation": "lte"
                        },
                        "leftValue": "={{ $json.anger_score }}",
                        "rightValue": 7
                      }
                    ]
                  },
                  "renameOutput": true
                },
                {
                  "outputKey": "Feedback",
                  "conditions": {
