          "parameters": {
            "options": {},
            "conditions": {
              "options": {
                "version": 3,
                "leftValue": "",
                "caseSensitive": true,
                "typeValidation": "strict"
              },
              "combinator": "and",
              "conditions": [
                {
                  "id": "629adb89-9e63-466b-b999-2a91a5ec1579",
                  "operator": {
                    "type": "boolean",
                    "operation": "true",
                    "singleValue": true
