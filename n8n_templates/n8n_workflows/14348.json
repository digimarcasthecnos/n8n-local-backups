          ],
          "parameters": {
            "jsCode": "return items.map((item, index) => {\n\n  // ✅ Jobs count\n  const jobs = $items(\"Fetch Job Openings\")[index]?.json?.data?.length || 0;\n\n  // ✅ Tech count\n  const tech = $items(\"Fetch Tech Stack\")[index]?.json?.data?.length || 0;\n\n  // ✅ News count (current node input)\n  const news = item.json.data?.length || 0;\n\n  // ✅ Domain (from Google Sheet - correct source)\n  const domain = $items(\"Get Prospect List\")[index]?.json?.domain || \"unknown\";\n\n  // ✅ Final scoring logic\n  const score = (jobs * 5) + (tech * 3) + (news * 2);\n\n  return {\n    json: {\n      domain,\n      hiring_signal: jobs,\n      tech_signal: tech,\n      news_signal: news,\n      intent_score: score\n    }\n  };\n});"
