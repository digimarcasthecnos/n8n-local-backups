          "parameters": {
            "jsCode": "const totalPages = Math.max(1, Number($input.first().json.data.data.result) || 1);\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const url = item.json.data.url;\n\n  output.push({ json: { url } });\n\n  for (let p = 2; p <= totalPages; p++) {\n    output.push({\n      json: {\n        url: `${url}/pg-${p}`,\n      },\n    });\n  }\n}\n\nreturn output;"
