          },
          "typeVersion": 1
        },
        {
          "id": "140bb95a-5122-49b3-8546-9a93c9a43530",
          "name": "Build Digest",
          "type": "n8n-nodes-base.code",
          "position": [
            2128,
            1904
          ],
          "parameters": {
            "jsCode": "// Build the formatted daily digest\nconst aiResponse = $input.first().json.text || '';\nconst articles = $('Merge and Deduplicate').first().json.articles;\nlet scored = [];\n\ntry {\n  const match = aiResponse.match(/\\[[\\s\\S]*\\]/);\n  if (match) scored = JSON.parse(match[0]);\n} catch (e) {\n  scored = articles.map((a, i) => ({\n    index: i + 1,\n    title: a.title,\n    summary: a.description.substring(0, 100),\n    score: 5,\n    category: 'other'\n  }));\n}\n\n// Sort by score descending\nscored.sort((a, b) => b.score - a.score);\n\n// Build Slack-formatted digest\nconst today = new Date().toISOString().split('T')[0];\nconst topStories = scored.filter(s => s.score >= 7);\nconst otherStories = scored.filter(s => s.score < 7);\n\nlet slackText = `📰 *Daily News Digest — ${today}*\\n\\n`;\n\nif (topStories.length > 0) {\n  slackText += `*🔥 Top Stories*\\n`;\n  topStories.forEach(s => {\n    const article = articles[s.index - 1];\n    slackText += `• *${s.title}* (⭐ ${s.score}/10)\\n  ${s.summary}\\n  ${article ? article.url : ''}\\n\\n`;\n  });\n}\n\nif (otherStories.length > 0) {\n  slackText += `*📋 Other News*\\n`;\n  otherStories.forEach(s => {\n    slackText += `• ${s.title} (${s.score}/10) — ${s.summary}\\n`;\n  });\n}\n\n// Build email HTML\nlet emailBody = `Daily News Digest — ${today}\\n\\n`;\nscored.forEach(s => {\n  const article = articles[s.index - 1];\n  emailBody += `[${s.score}/10] ${s.title}\\n${s.summary}\\n${article ? article.url : ''}\\n\\n`;\n});\n\nreturn [{\n  json: {\n    slackText,\n    emailBody,\n    date: today,\n    totalArticles: scored.length,\n    topStoriesCount: topStories.length\n  }\n}];"
          },
          "typeVersion": 2
        },
