          "name": "Check Campaign Progress",
          "type": "n8n-nodes-base.httpRequest",
          "position": [
            1540,
            0
          ],
          "parameters": {
            "url": "={{ 'https://apiv2.waiflow.app/api/v2/bulk-send/' + $('Create Bulk Send Job').first().json.id }}",
            "method": "GET",
