          "id": "a61610f9-aff7-4bd4-a397-d7338c312959",
          "name": "Strict Payload Validation",
          "type": "n8n-nodes-base.code",
          "position": [
            1376,
            -16
          ],
          "parameters": {
            "jsCode": "// 🛡️ 1. Secure JSON parsing\nlet data;\ntry {\n  data = JSON.parse($json.rawBody);\n} catch (e) {\n  return [{ json: { valid: false, error: 'Invalid or malformed JSON' } }];\n}\n\n// 🎯 2. Required field check\nif (!data.prompt) {\n  return [{ json: { valid: false, error: \"Missing required field: 'prompt'\" } }];\n}\n\n// 🔒 3. Strict whitelist filtering against parameter injection\nconst allowedKeys = ['prompt'];\nfor (const key of Object.keys(data)) {\n  if (!allowedKeys.includes(key)) {\n    return [{ json: { valid: false, error: `Unexpected field: '${key}'` } }];\n  }\n}\n\n// ✅ 4. Validation passed — forward clean data\nreturn [{ json: { valid: true, data } }];"
          },
          "typeVersion": 2
        },
