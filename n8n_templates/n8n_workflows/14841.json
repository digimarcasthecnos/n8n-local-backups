            -176
          ],
          "parameters": {
            "color": 7,
            "width": 688,
            "height": 288,
            "content": "## Kick-Off workflow\n\nSearches Airtable and uses AI to extract website data and create a social media post with Dumpling AI and Claude respectively."
          },
          "typeVersion": 1
        },
        {
          "id": "196535a9-007c-42d5-bbae-e1dff9a72cca",
